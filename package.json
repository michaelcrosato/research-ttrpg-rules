{
  "name": "research-ttrpg-rules",
  "version": "1.0.0",
  "description": "Rules Explorer application",
  "main": "app.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run data:taxonomy && tsc && node strip-exports.js",
    "build:watch": "tsc -w",
    "start": "npx -y serve .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run build",
    "test": "node tests/run-tests.js --runInBand",
    "typecheck": "tsc --noEmit",
    "data:taxonomy": "node scripts/build_taxonomy.js",
    "data:validate": "node scripts/validate_registry.js",
    "data:stats": "node scripts/stats.js",
    "data:merge": "node scripts/merge_curated.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "3.5.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
